            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@malgn.com\",\n  \"password\": \"user123\"\n}"
            }
          }
        },
        {
          "name": "2. 관리자 게시글 수정 시도 → 403",
          "request": {
