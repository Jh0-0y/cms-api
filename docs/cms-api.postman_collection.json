            "url": { "raw": "{{baseUrl}}/api/contents/3", "host": ["{{baseUrl}}"], "path": ["api", "contents", "3"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"수정 시도\",\n  \"description\": \"403이 반환되어야 합니다.\"\n}"
            }
          }
        },
        {
          "name": "6. 로그인 (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@malgn.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "7. 타인 게시글 수정 (ADMIN) → 200",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/contents/3", "host": ["{{baseUrl}}"], "path": ["api", "contents", "3"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"ADMIN이 수정함\",\n  \"description\": \"ADMIN은 모든 게시글 수정 가능\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "시나리오 2 - 소프트 삭제 & 복구",
      "description": "소프트 삭제된 콘텐츠는 조회 불가, 복구 후 다시 조회 가능한지 검증합니다.",
      "item": [
        {
