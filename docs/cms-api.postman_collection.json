            "url": { "raw": "{{baseUrl}}/api/contents/3", "host": ["{{baseUrl}}"], "path": ["api", "contents", "3"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"맑은사원이 수정함\",\n  \"description\": \"본인 게시글 수정 성공\"\n}"
            }
          }
        },
        {
          "name": "4. 로그인 (하늘사원)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user2@malgn.com\",\n  \"password\": \"user456\"\n}"
            }
          }
