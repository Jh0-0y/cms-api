{
  "info": {
    "name": "Simple CMS REST API",
    "description": "Simple CMS REST API Postman Collection\n\n로그인 후 쿠키가 자동으로 저장되어 인증이 필요한 API에 자동으로 포함됩니다.\nPostman 설정에서 'Automatically follow redirects'와 'Send cookies' 옵션이 활성화되어 있어야 합니다.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "회원가입",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/signup", "host": ["{{baseUrl}}"], "path": ["api", "auth", "signup"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"newuser@malgn.com\",\n  \"username\": \"신규사원\",\n  \"nickname\": \"신규닉네임\",\n  \"password\": \"password123\",\n  \"passwordConfirm\": \"password123\"\n}"
            }
          }
        },
        {
          "name": "로그인 (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@malgn.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "로그인 (USER - 맑은사원)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@malgn.com\",\n  \"password\": \"user123\"\n}"
            }
          }
        },
        {
          "name": "로그인 (USER - 하늘사원)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user2@malgn.com\",\n  \"password\": \"user456\"\n}"
            }
          }
        },
        {
          "name": "Access Token 재발급",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/refresh", "host": ["{{baseUrl}}"], "path": ["api", "auth", "refresh"] }
          }
        },
        {
          "name": "로그아웃",
          "request": {
            "method": "POST",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/auth/logout", "host": ["{{baseUrl}}"], "path": ["api", "auth", "logout"] }
          }
        }
      ]
    },
    {
      "name": "Members",
      "item": [
        {
          "name": "내 정보 조회",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/members/me", "host": ["{{baseUrl}}"], "path": ["api", "members", "me"] }
          }
        },
        {
          "name": "닉네임 변경",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/members/me/nickname", "host": ["{{baseUrl}}"], "path": ["api", "members", "me", "nickname"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"nickname\": \"변경된닉네임\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Contents",
      "item": [
        {
          "name": "콘텐츠 목록 조회",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/contents?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contents"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "keyword", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "콘텐츠 목록 조회 (키워드 검색)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/contents?keyword=사원",
              "host": ["{{baseUrl}}"],
              "path": ["api", "contents"],
              "query": [
                { "key": "keyword", "value": "사원" }
              ]
            }
          }
        },
        {
          "name": "콘텐츠 단건 조회",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/contents/1", "host": ["{{baseUrl}}"], "path": ["api", "contents", "1"] }
          }
        },
        {
          "name": "콘텐츠 생성",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/contents", "host": ["{{baseUrl}}"], "path": ["api", "contents"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"새 콘텐츠 제목\",\n  \"description\": \"새 콘텐츠 내용입니다.\"\n}"
            }
          }
        },
        {
          "name": "콘텐츠 수정",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/contents/3", "host": ["{{baseUrl}}"], "path": ["api", "contents", "3"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"수정된 제목\",\n  \"description\": \"수정된 내용입니다.\"\n}"
            }
          }
        },
        {
          "name": "콘텐츠 삭제",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/contents/3", "host": ["{{baseUrl}}"], "path": ["api", "contents", "3"] }
          }
        },
        {
          "name": "콘텐츠 복구",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/contents/4/restore", "host": ["{{baseUrl}}"], "path": ["api", "contents", "4", "restore"] }
          }
        }
      ]
    },
    {
      "name": "시나리오 1 - 권한 검증",
      "description": "USER끼리 서로 수정/삭제 불가, ADMIN은 모두 가능한지 검증합니다.",
      "item": [
        {
          "name": "1. 로그인 (맑은사원)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
